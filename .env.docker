APP_NAME="Agent Bus"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://your-domain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=host.docker.internal   # ganti dengan IP/host MySQL Anda
DB_PORT=3306
DB_DATABASE=agent_bus
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local
